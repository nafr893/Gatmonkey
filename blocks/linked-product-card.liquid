{% liquid
  assign s = block.settings
  assign product_count = 0
  for n in (1..6)
    assign key = 'product_' | append: n
    if s[key] != blank
      assign product_count = product_count | plus: 1
    endif
  endfor
%}

{% if product_count > 0 %}
  <script src="{{ 'linked-product-card.js' | asset_url }}" defer></script>

  <div
    class="skre-lpc spacing-style"
    style="{% render 'spacing-style', settings: s %}"
    data-block-id="{{ block.id }}"
    {{ block.shopify_attributes }}
  >
    {% if s.heading != blank or product_count > 1 %}
      <div class="skre-lpc__header">
        {% if s.heading != blank %}
          <p class="skre-lpc__heading">{{ s.heading }}</p>
        {% else %}
          <span></span>
        {% endif %}
        {% if product_count > 1 %}
          <div class="skre-lpc__arrows">
            <button type="button" class="skre-lpc__arrow" data-lpc-prev aria-label="Previous" disabled>
              <svg width="10" height="16" viewBox="0 0 10 16" fill="none" aria-hidden="true">
                <path d="M8.5 1.5L1.5 8L8.5 14.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button type="button" class="skre-lpc__arrow" data-lpc-next aria-label="Next">
              <svg width="10" height="16" viewBox="0 0 10 16" fill="none" aria-hidden="true">
                <path d="M1.5 1.5L8.5 8L1.5 14.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="skre-lpc__track" data-lpc-track>
      {% for n in (1..6) %}
        {% assign key = 'product_' | append: n %}
        {% assign linked = s[key] %}
        {% if linked != blank %}
          {% assign fv = linked.selected_or_first_available_variant %}
          <div class="skre-lpc__card">

            <div class="skre-lpc__card-top">
              {% if linked.featured_image %}
                <img
                  class="skre-lpc__thumb"
                  src="{{ linked.featured_image | image_url: width: 160 }}"
                  alt="{{ linked.featured_image.alt | default: linked.title | escape }}"
                  width="72"
                  height="72"
                  loading="lazy"
                >
              {% endif %}

              <div class="skre-lpc__info">
                <p class="skre-lpc__title">{{ linked.title }}</p>

                {% unless linked.has_only_default_variant %}
                  <p class="skre-lpc__selected-label" data-lpc-selected-label>
                    {{ linked.options.first }}:&nbsp;<span>{{ fv.title }}</span>
                  </p>
                  <div class="skre-lpc__variants" role="group" aria-label="{{ linked.title }} variants">
                    {% for variant in linked.variants %}
                      <button
                        type="button"
                        class="skre-lpc__variant-btn{% if forloop.first %} skre-lpc__variant-btn--selected{% endif %}"
                        data-lpc-variant-btn
                        data-variant-id="{{ variant.id }}"
                        data-variant-price="{{ variant.price | money }}"
                        data-variant-title="{{ variant.title | escape }}"
                        aria-pressed="{{ forloop.first }}"
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {{- variant.title -}}
                      </button>
                    {% endfor %}
                  </div>
                {% endunless %}

                <p class="skre-lpc__price" data-lpc-price>
                  {{- fv.price | money -}}
                  {% if fv.compare_at_price > fv.price %}
                    &nbsp;<s class="skre-lpc__compare-price">{{ fv.compare_at_price | money }}</s>
                  {% endif %}
                </p>
              </div>

              <button
                type="button"
                class="skre-lpc__add-btn"
                data-lpc-add-btn
                data-selected-variant="{{ fv.id }}"
                aria-label="Add {{ linked.title | escape }} to cart"
              >
                {{- s.button_label | default: 'Add +' -}}
              </button>
            </div>

            <div class="skre-lpc__qty-row" data-lpc-qty-row aria-hidden="true">
              <span class="skre-lpc__added-label">
                Added &mdash; <strong data-lpc-added-price>{{ fv.price | money }}</strong>
              </span>
              <div class="skre-lpc__qty-controls">
                <button type="button" class="skre-lpc__qty-btn" data-lpc-qty-minus aria-label="Decrease quantity">−</button>
                <span class="skre-lpc__qty-value" data-lpc-qty-value>1</span>
                <button type="button" class="skre-lpc__qty-btn" data-lpc-qty-plus aria-label="Increase quantity">+</button>
                <button type="button" class="skre-lpc__remove-btn" data-lpc-remove>Remove</button>
              </div>
            </div>

          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
{% endif %}

{% stylesheet %}
  /* ── Mobile: native horizontal scroll (single-column layout, no blowout risk) ── */
  .skre-lpc {
    min-width: 0;
  }

  .skre-lpc__track {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 2px;
  }

  .skre-lpc__track::-webkit-scrollbar {
    display: none;
  }

  .skre-lpc__card {
    flex-shrink: 0;
    flex-basis: auto;
    width: 88%;
    scroll-snap-align: start;
    border: 1px solid rgb(var(--color-border-rgb) / 0.35);
    border-radius: var(--style-border-radius-cards, 4px);
    overflow: hidden;
  }

  /* ── Desktop: forced rem width — no percentages, no scroll container ── */
  @media screen and (min-width: 750px) {
    .skre-lpc {
      width: 38rem;
      max-width: 100%;
      overflow: hidden;
    }

    .skre-lpc__track {
      overflow-x: visible;
      scroll-snap-type: none;
      transition: transform 0.3s ease;
    }

    .skre-lpc__card {
      flex: 0 0 38rem;
      max-width: 100%;
      scroll-snap-align: none;
    }
  }


  /* ── Header row: heading + arrows ── */
  .skre-lpc__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .skre-lpc__heading {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .skre-lpc__arrows {
    display: flex;
    gap: 0.5rem;
  }

  .skre-lpc__arrow {
    appearance: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgb(var(--color-border-rgb) / 0.5);
    background: transparent;
    color: var(--color-foreground);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s, opacity 0.15s;
    flex-shrink: 0;
  }

  .skre-lpc__arrow:hover {
    background: rgb(var(--color-foreground-rgb) / 0.06);
  }

  .skre-lpc__arrow:disabled {
    opacity: 0.3;
    cursor: default;
  }

  /* Arrows: hidden on mobile (native swipe), visible on desktop (transform carousel) */
  .skre-lpc__arrows {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .skre-lpc__arrows {
      display: flex;
    }
  }

  /* ── Card top row ── */
  .skre-lpc__card-top {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.85rem;
  }

  .skre-lpc__thumb {
    flex: 0 0 auto;
    width: 72px;
    height: 72px;
    object-fit: cover;
    border-radius: 4px;
  }

  .skre-lpc__info {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .skre-lpc__title {
    margin: 0;
    font-size: var(--font-size--sm);
    font-weight: 700;
  }

  .skre-lpc__selected-label {
    margin: 0;
    font-size: var(--font-size--sm);
    opacity: 0.65;
  }

  .skre-lpc__variants {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .skre-lpc__variant-btn {
    appearance: none;
    padding: 3px 8px;
    border: 1px solid var(--color-border);
    border-radius: var(--style-border-radius-pills, 4px);
    background: transparent;
    color: var(--color-foreground);
    font-family: inherit;
    font-size: 0.7rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
  }

  .skre-lpc__variant-btn--selected {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }

  .skre-lpc__variant-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .skre-lpc__price {
    margin: 0;
    font-size: var(--font-size--sm);
    font-weight: 700;
  }

  .skre-lpc__compare-price {
    font-weight: 400;
    opacity: 0.5;
  }

  /* ── ADD + button ── */
  .skre-lpc__add-btn {
    flex: 0 0 auto;
    appearance: none;
    padding: 0.65rem 0.9rem;
    border: 2px solid var(--color-foreground);
    border-radius: var(--style-border-radius-buttons, 4px);
    background: transparent;
    color: var(--color-foreground);
    font-family: inherit;
    font-size: var(--font-size--sm);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.15s, color 0.15s, opacity 0.15s;
    align-self: center;
  }

  .skre-lpc__add-btn:hover {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .skre-lpc__add-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ── Quantity row — slides down after adding ── */
  .skre-lpc__qty-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-inline: 0.85rem;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.28s ease, opacity 0.2s ease, padding 0.28s ease;
    border-top: 0px solid rgb(var(--color-border-rgb) / 0.25);
  }

  .skre-lpc__qty-row--visible {
    max-height: 56px;
    opacity: 1;
    padding-block: 0.65rem;
    border-top-width: 1px;
  }

  .skre-lpc__added-label {
    font-size: var(--font-size--sm);
    white-space: nowrap;
  }

  .skre-lpc__qty-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .skre-lpc__qty-btn {
    appearance: none;
    width: 28px;
    height: 28px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: transparent;
    color: var(--color-foreground);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.12s;
  }

  .skre-lpc__qty-btn:hover {
    background: rgb(var(--color-foreground-rgb) / 0.08);
  }

  .skre-lpc__qty-value {
    font-size: var(--font-size--sm);
    font-weight: 600;
    min-width: 1.25rem;
    text-align: center;
  }

  .skre-lpc__remove-btn {
    appearance: none;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--color-foreground);
    font-family: inherit;
    font-size: var(--font-size--sm);
    cursor: pointer;
    opacity: 0.6;
    text-decoration: underline;
    white-space: nowrap;
  }

  .skre-lpc__remove-btn:hover {
    opacity: 1;
  }
{% endstylesheet %}

