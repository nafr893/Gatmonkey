{%- doc -%}
  Renders a default variant picker, used to display the variant picker in the variants block.

  @param {object} product_resource - The product object.
  @param {object} [block] - The block object
  @param {object} section - The section object.
  @param {object} product - The current product object (used to determine selected variant state).
{%- enddoc -%}

{% assign block_settings = block.settings %}

{% unless product_resource.has_only_default_variant %}
  {% liquid
    assign button_background_brightness = section.settings.color_scheme.settings.foreground | color_brightness
    if button_background_brightness < 105
      assign strikethrough_color_mix = '#000'
    else
      assign strikethrough_color_mix = '#fff'
    endif
  %}
  <variant-picker
    class="variant-picker spacing-style variant-picker--{{ block_settings.alignment }}"
    style="--color-strikethrough-mix: {{ strikethrough_color_mix }}; {% render 'spacing-style', settings: block_settings %}"
    data-section-id="{{ section.id }}"
    data-product-id="{{ product_resource.id }}"
    data-block-id="{{ block.id }}"
    data-product-url="{{ product_resource.url }}"
    ref="mainVariantPicker"
    {% if product.id == product_resource.id %}
      data-template-product-match="true"
    {% endif %}
    {{ block.shopify_attributes }}
    {% if request.visual_preview_mode %}
      data-shopify-visual-preview
    {% endif %}
  >
    <form class="variant-picker__form">
      {%- for product_option in product_resource.options_with_values -%}
        {%- liquid
          assign swatch_count = product_option.values | map: 'swatch' | compact | size
          assign media_count = product_option.values | map: 'variant' | map: 'featured_media' | compact | size
          assign variant_style = block_settings.variant_style

          if swatch_count > 0 or media_count > 0
            if block_settings.show_swatches
              if block_settings.variant_style == 'dropdown'
                assign variant_style = 'swatch_dropdown'
              else
                assign variant_style = 'swatch'
              endif
            endif
          endif

          if variant_style == 'buttons' and settings.variant_button_width == 'equal-width-buttons'
            assign fieldset_id = section.id | append: '-' | append: product_resource.id | append: '-' | append: product_option.name | handleize
            assign option_id_attribute = 'data-option-id="' | append: fieldset_id | append: '"'
            assign longest_value = 0
          endif
        -%}

        {%- if product_option.values.size == 1 and variant_style != 'swatch' -%}
          <div
            class="variant-option"
            data-testid="variant-option-single"
          >
            {{- product_option.name | capitalize | escape -}}
            <span
              class="variant-option__swatch-value"
              data-testid="variant-option-single-value"
            >
              {{- product_option.selected_value -}}
            </span>
          </div>
        {%- elsif variant_style == 'swatch' or block_settings.variant_style == 'buttons' -%}
          {%- assign fieldset_index = forloop.index0 -%}
          <fieldset
            class="variant-option variant-option--buttons{% if variant_style == 'swatch' %} variant-option--swatches{% else %} variant-option--{{ settings.variant_button_width }}{% endif %}"
            data-fieldset-index="{{ fieldset_index }}"
            ref="fieldsets[]"
            {{ option_id_attribute }}
          >
            <legend>
              {{ product_option.name | capitalize | escape -}}
              {%- if variant_style == 'swatch' -%}
                <span class="variant-option__swatch-value">{{ product_option.selected_value }}</span>
              {%- endif %}
            </legend>
            {%- for product_option_value in product_option.values -%}
              {% if product_option_value.size > longest_value and option_id_attribute %}
                {% assign longest_value = product_option_value.size %}
              {% endif %}
              <label
                class="variant-option__button-label{% if variant_style == 'swatch' %} variant-option__button-label--has-swatch{% endif %}"
              >
                <input
                  type="radio"
                  name="{{ product_option.name | capitalize | escape }}-{{ block.id }}-{{ product_resource.id }}"
                  value="{{ product_option_value | escape }}"
                  aria-label="{{ product_option_value.name | escape }}{% if product_option_value.available == false %} - {{ 'products.product.sold_out' | t }}{% endif %}"
                  {% if product_option_value.available == false %}
                    aria-disabled="true"
                  {% endif %}
                  data-previous-checked="false"
                  data-fieldset-index="{{ fieldset_index }}"
                  data-input-index="{{ forloop.index0 }}"
                  data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
                  data-option-value-id="{{ product_option_value.id }}"
                  data-option-available="{{ product_option_value.available }}"
                  data-connected-product-url="{{ product_option_value.product_url }}"
                  {% if product_option_value.variant.id %}
                    data-variant-id="{{ product_option_value.variant.id }}"
                  {% endif %}
                  {% if product_option_value.selected %}
                    data-current-checked="true"
                    checked
                  {% else %}
                    data-current-checked="false"
                  {% endif %}
                >
                {% if variant_style == 'swatch' %}
                  {% liquid
                    assign featured_media = product_option_value.variant.featured_media

                    # If the variant has no featured media, and we have a combined listing product, then fall back to
                    # using the featured media of the child product that is linked to this option value.
                    if featured_media == blank and product_option_value.product_url
                      assign featured_media = product_option_value.variant.product.featured_media
                    endif
                  %}

                  {% render 'swatch',
                    swatch: product_option_value.swatch,
                    variant_image: featured_media,
                    mode: 'unscaled'
                  %}
                {% else %}
                  {% if product_option_value.available == true %}
                    <span
                      class="variant-option__button-label__pill"
                      data-key="variant-option-pill"
                    ></span>
                  {% endif %}
                  <span
                    class="variant-option__button-label__text"
                    data-key="variant-option-text"
                  >
                    {{- product_option_value | escape -}}
                  </span>
                {% endif %}
                {% render 'strikethrough-variant', product_option: product_option_value %}
              </label>
            {%- endfor -%}
            {% if option_id_attribute %}
              {% style %}
                [data-option-id="{{ fieldset_id }}"] {
                  --variant-ch: {{ longest_value | times: 0.65 }}em;
                }
              {% endstyle %}
            {% endif %}
          </fieldset>
        {%- elsif block_settings.variant_style == 'dropdowns' -%}
          {%
            # There is an opportunity to build a custom select component that will allow us to style the select element further (animation for dropdown, swatches shown in the dropdown options, etc)
            # It's too bad as it mean rebuilding baked in behaviours but I think we've already done that for the locale selectors
            # in dawn. So it might mean more time spent in setting it up but worth it for future updates/styling.
          %}
          {% liquid
            assign property_being_updated = false
            if settings.variant_swatch_width != settings.variant_swatch_height
              assign property_being_updated = true
              # (original width / original height) x new height (20px at the moment) = new width
              assign new_width = settings.variant_swatch_width | times: 1.0 | divided_by: settings.variant_swatch_height | times: 20
            endif
          %}

          <div class="variant-option variant-option--dropdowns">
            <label for="Option-{{ block.id }}-{{ forloop.index0 }}">{{ product_option.name | capitalize | escape }}</label>
            <div
              class="variant-option__select-wrapper"
              style="
                {%- if property_being_updated  -%}
                  --variant-picker-swatch-width: clamp(10px,{{ new_width }}px, 50px);
                {%- endif -%}
              "
            >
              <select
                id="Option-{{ block.id }}-{{ forloop.index0 }}"
                name="options[{{ product_option.name | capitalize | escape }}]"
                class="variant-option__select"
              >
                {%- for product_option_value in product_option.values -%}
                  <option
                    value="{{ product_option_value | escape }}"
                    data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
                    data-option-value-id="{{ product_option_value.id }}"
                    data-variant-id="{{ product_option_value.variant.id }}"
                    data-connected-product-url="{{ product_option_value.product_url }}"
                    {% if product_option_value.selected %}
                      selected="selected"
                    {% endif %}
                  >
                    {% if product_option_value.available == false %}
                      {{ product_option_value | escape }} - {{ 'content.unavailable' | t }}
                    {% else %}
                      {{ product_option_value | escape }}
                    {% endif %}
                  </option>
                {%- endfor -%}
              </select>
              <svg
                aria-hidden="true"
                focusable="false"
                class="icon icon-caret"
                viewBox="0 0 10 6"
              >
                {%- render 'icon', icon: 'caret' -%}
              </svg>
            </div>
          </div>
        {%- elsif block_settings.variant_style == 'overlay' -%}
          {%- assign overlay_option_index = forloop.index0 -%}
          {%- assign fieldset_index = forloop.index0 -%}

          <div class="variant-option variant-option--overlay">
            <label for="skre-sov-btn-{{ block.id }}-{{ overlay_option_index }}">
              {{- product_option.name | capitalize | escape -}}
            </label>
            <div class="variant-option__select-wrapper">
              <button
                type="button"
                id="skre-sov-btn-{{ block.id }}-{{ overlay_option_index }}"
                class="skre-sov-trigger variant-option__select"
                data-block-id="{{ block.id }}"
                data-option-index="{{ overlay_option_index }}"
                aria-haspopup="dialog"
                aria-expanded="false"
              >
                <span class="skre-sov-trigger__value">{{- product_option.selected_value -}}</span>
              </button>
              <svg aria-hidden="true" focusable="false" class="icon icon-caret" viewBox="0 0 10 6">
                {%- render 'icon', icon: 'caret' -%}
              </svg>
            </div>
          </div>

          <fieldset
            class="variant-option variant-option--buttons skre-sov-fieldset"
            data-fieldset-index="{{ fieldset_index }}"
            ref="fieldsets[]"
            aria-hidden="true"
          >
            <legend>{{ product_option.name | capitalize | escape }}</legend>
            {%- for product_option_value in product_option.values -%}
              <label class="variant-option__button-label">
                <input
                  type="radio"
                  name="{{ product_option.name | capitalize | escape }}-{{ block.id }}-{{ product_resource.id }}"
                  value="{{ product_option_value | escape }}"
                  aria-label="{{ product_option_value.name | escape }}{% if product_option_value.available == false %} - {{ 'products.product.sold_out' | t }}{% endif %}"
                  {% if product_option_value.available == false %}aria-disabled="true"{% endif %}
                  data-previous-checked="false"
                  data-fieldset-index="{{ fieldset_index }}"
                  data-input-index="{{ forloop.index0 }}"
                  data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
                  data-option-value-id="{{ product_option_value.id }}"
                  data-option-available="{{ product_option_value.available }}"
                  data-connected-product-url="{{ product_option_value.product_url }}"
                  {% if product_option_value.variant.id %}data-variant-id="{{ product_option_value.variant.id }}"{% endif %}
                  {% if product_option_value.selected %}
                    data-current-checked="true"
                    checked
                  {% else %}
                    data-current-checked="false"
                  {% endif %}
                >
                <span class="variant-option__button-label__text">{{- product_option_value | escape -}}</span>
                {% render 'strikethrough-variant', product_option: product_option_value %}
              </label>
            {%- endfor -%}
          </fieldset>

          <div
            class="skre-sov"
            id="skre-sov-{{ block.id }}-{{ overlay_option_index }}"
            data-block-id="{{ block.id }}"
            data-option-index="{{ overlay_option_index }}"
            role="dialog"
            aria-modal="true"
            aria-label="{{ product_option.name | capitalize | escape }}"
            hidden
          >
            <div class="skre-sov__panel">
              <div class="skre-sov__header">
                <span class="skre-sov__title">Select Your Size</span>
                <button
                  type="button"
                  class="skre-sov__close"
                  data-block-id="{{ block.id }}"
                  data-option-index="{{ overlay_option_index }}"
                  aria-label="Close"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <path d="M14 4L4 14M4 4l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </button>
              </div>
              <div class="skre-sov__body">
                {%- for product_option_value in product_option.values -%}
                  <div
                    class="skre-sov__row{% if product_option_value.selected %} skre-sov__row--selected{% endif %}{% if product_option_value.available == false %} skre-sov__row--oos{% endif %}"
                    data-block-id="{{ block.id }}"
                    data-option-index="{{ overlay_option_index }}"
                    data-value="{{ product_option_value | escape }}"
                    {% if product_option_value.available == false %}data-oos="true"{% endif %}
                    role="button"
                    tabindex="{% if product_option_value.available %}0{% else %}-1{% endif %}"
                    aria-label="{{ product_option_value | escape }}{% if product_option_value.available == false %} - Out of stock{% endif %}"
                  >
                    <span class="skre-sov__row-label">{{- product_option_value | escape -}}</span>
                    {%- if product_option_value.available == false -%}
                      <span class="skre-sov__row-oos-label">Out Of Stock</span>
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <script type="application/json">
        {{ product_resource.selected_or_first_available_variant | json }}
      </script>
    </form>
  </variant-picker>

  {%- if block_settings.variant_style == 'overlay' -%}
    <script>
      (function () {
        var bid = '{{ block.id }}';
        window.__skrSov = window.__skrSov || {};
        if (window.__skrSov[bid]) return;
        window.__skrSov[bid] = true;

        function openOverlay(optionIdx) {
          var sheet = document.getElementById('skre-sov-' + bid + '-' + optionIdx);
          if (!sheet) return;
          sheet.removeAttribute('hidden');
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              var panel = sheet.querySelector('.skre-sov__panel');
              if (panel) panel.classList.add('skre-sov__panel--open');
            });
          });
          var trig = document.querySelector('.skre-sov-trigger[data-block-id="' + bid + '"][data-option-index="' + optionIdx + '"]');
          if (trig) trig.setAttribute('aria-expanded', 'true');
        }

        function closeOverlay(optionIdx) {
          var sheet = document.getElementById('skre-sov-' + bid + '-' + optionIdx);
          if (!sheet) return;
          var panel = sheet.querySelector('.skre-sov__panel');
          if (panel) panel.classList.remove('skre-sov__panel--open');
          var trig = document.querySelector('.skre-sov-trigger[data-block-id="' + bid + '"][data-option-index="' + optionIdx + '"]');
          if (trig) {
            trig.setAttribute('aria-expanded', 'false');
            trig.focus();
          }
          setTimeout(function () { sheet.setAttribute('hidden', ''); }, 360);
        }

        document.addEventListener('click', function (e) {
          var trigger = e.target.closest('.skre-sov-trigger[data-block-id="' + bid + '"]');
          if (trigger) { openOverlay(trigger.dataset.optionIndex); return; }

          var closeBtn = e.target.closest('.skre-sov__close[data-block-id="' + bid + '"]');
          if (closeBtn) { closeOverlay(closeBtn.dataset.optionIndex); return; }

          var backdrop = e.target.closest('.skre-sov[data-block-id="' + bid + '"]');
          if (backdrop && !e.target.closest('.skre-sov__panel')) {
            closeOverlay(backdrop.dataset.optionIndex);
            return;
          }

          var row = e.target.closest('.skre-sov__row[data-block-id="' + bid + '"]');
          if (row && !row.dataset.oos) {
            var optionIdx = row.dataset.optionIndex;
            var value = row.dataset.value;
            var vp = document.querySelector('variant-picker[data-block-id="' + bid + '"]');
            if (!vp) return;
            var inputs = vp.querySelectorAll('input[type="radio"][data-fieldset-index="' + optionIdx + '"]');
            var radio = null;
            for (var i = 0; i < inputs.length; i++) {
              if (inputs[i].value === value) { radio = inputs[i]; break; }
            }
            if (!radio) return;
            radio.checked = true;
            radio.dispatchEvent(new Event('change', { bubbles: true }));
            var sheet = document.getElementById('skre-sov-' + bid + '-' + optionIdx);
            if (sheet) {
              sheet.querySelectorAll('.skre-sov__row').forEach(function (r) {
                r.classList.toggle('skre-sov__row--selected', r === row);
              });
            }
            var trig = document.querySelector('.skre-sov-trigger[data-block-id="' + bid + '"][data-option-index="' + optionIdx + '"]');
            if (trig) {
              var valSpan = trig.querySelector('.skre-sov-trigger__value');
              if (valSpan) valSpan.textContent = value;
            }
            setTimeout(function () { closeOverlay(optionIdx); }, 120);
          }
        });

        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') {
            var openSheet = document.querySelector('.skre-sov[data-block-id="' + bid + '"]:not([hidden])');
            if (openSheet) closeOverlay(openSheet.dataset.optionIndex);
            return;
          }
          if (e.key === 'Enter' || e.key === ' ') {
            var row = e.target.closest('.skre-sov__row[data-block-id="' + bid + '"]');
            if (row && !row.dataset.oos) { e.preventDefault(); row.click(); }
          }
        });
      })();
    </script>
  {%- endif -%}
{% endunless %}

{% stylesheet %}
  /* Variant picker container styles - unique to main variant picker */
  .variant-picker {
    width: 100%;
  }

  .variant-picker__form {
    width: 100%;
  }

  .variant-picker[data-shopify-visual-preview] {
    min-width: 300px;
    padding-inline-start: max(4px, var(--padding-inline-start));
  }

  /* Dropdown variant option styles */
  .variant-option__select-wrapper {
    display: flex;
    position: relative;
    border: var(--style-border-width-inputs) solid var(--color-border);
    border-radius: var(--style-border-radius-inputs);
    align-items: center;
    margin-top: var(--margin-2xs);
    overflow: clip;
  }

  .variant-option__select-wrapper:has(.swatch) {
    --variant-picker-swatch-width: 20px;
    --variant-picker-swatch-height: 20px;
  }

  .variant-option__select-wrapper:hover {
    border-color: var(--color-variant-hover-border);
  }

  .variant-option__select:focus-visible {
    outline: var(--focus-outline-width) solid currentcolor;
    outline-offset: var(--focus-outline-offset);
  }

  .variant-option__select {
    padding-block: var(--padding-md);
    padding-inline: var(--padding-lg) calc(var(--padding-lg) + var(--icon-size-2xs));
    appearance: none;
    border: 0;
    width: 100%;
    margin: 0;
    cursor: pointer;
  }

  .variant-option__select-wrapper .icon {
    position: absolute;
    right: var(--padding-md);
    top: 50%;
    transform: translateY(-50%);
    width: var(--icon-size-2xs);
    height: var(--icon-size-2xs);
    pointer-events: none;
  }

  .variant-option__select--has-swatch {
    padding-inline-start: calc((2 * var(--padding-sm)) + var(--variant-picker-swatch-width));
  }

  .variant-option__select-wrapper .swatch {
    position: absolute;
    top: 50%;
    left: var(--padding-md);
    transform: translateY(-50%);
  }

  /* Variant picker alignment modifiers */
  .variant-picker--center,
  .variant-picker--center .variant-option {
    text-align: center;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .variant-picker--right,
  .variant-picker--right .variant-option {
    text-align: right;
    justify-content: right;
  }
  /* ── Size overlay variant picker ── */
  .skre-sov-fieldset {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }

  @media screen and (min-width: 750px) {
    .variant-option--overlay {
      display: none;
    }
    .skre-sov {
      display: none !important;
    }
    .skre-sov-fieldset {
      position: static;
      opacity: 1;
      pointer-events: auto;
      width: auto;
      height: auto;
      overflow: visible;
      clip: auto;
    }
  }

  .skre-sov-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: transparent;
    border: 0;
    text-align: left;
    cursor: pointer;
    font: inherit;
    color: inherit;
  }

  .skre-sov-trigger:hover,
  .skre-sov-trigger:focus,
  .skre-sov-trigger:focus-visible {
    color: inherit;
    outline: none;
  }

  .skre-sov {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: flex-end;
  }

  .skre-sov[hidden] {
    display: none;
  }

  .skre-sov__panel {
    width: 100%;
    background: #fff;
    border-radius: 0;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    max-height: 80vh;
    overflow-y: auto;
  }

  .skre-sov__panel--open {
    transform: translateY(0);
  }

  .skre-sov__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid #ededed;
    position: sticky;
    top: 0;
    background: #fff;
    z-index: 1;
  }

  .skre-sov__title {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .skre-sov__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    color: inherit;
    line-height: 1;
  }

  .skre-sov__body {
    padding-bottom: env(safe-area-inset-bottom, 0);
  }

  .skre-sov__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid #ededed;
    cursor: pointer;
    user-select: none;
    transition: background 0.1s ease;
  }

  .skre-sov__row:last-child {
    border-bottom: none;
  }

  .skre-sov__row--selected {
    background: #000;
    color: #fff;
  }

  .skre-sov__row--selected .skre-sov__row-label {
    color: #fff;
  }

  .skre-sov__row--oos {
    background: #f8f8f6;
    cursor: default;
  }

  .skre-sov__row-label {
    font-size: 0.9375rem;
    font-weight: 500;
    color: inherit;
  }

  .skre-sov__row--oos .skre-sov__row-label {
    color: #aaa;
  }

  .skre-sov__row-oos-label {
    font-size: 0.75rem;
    font-weight: 400;
    color: #aaa;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
{% endstylesheet %}
